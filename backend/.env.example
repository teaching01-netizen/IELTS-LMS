# API runtime
API_HOST=0.0.0.0
API_PORT=4000
# Use RESOURCE_PROFILE=low for tiny one-instance deployments around 1 CPU, 1 GiB RAM, and 5 GiB disk.
RESOURCE_PROFILE=
WORKER_CONCURRENCY=4

# Database
DATABASE_URL=mysql://root:root@127.0.0.1:4000/ielts
DATABASE_DIRECT_URL=mysql://root:root@127.0.0.1:4000/ielts
DATABASE_MIGRATOR_URL=mysql://root:root@127.0.0.1:4000/ielts
DATABASE_WORKER_URL=mysql://root:root@127.0.0.1:4000/ielts
DB_POOL_MIN_CONNECTIONS=4
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_ACQUIRE_TIMEOUT_MS=3000
WORKER_POLL_INTERVAL_MS=1000
WORKER_FALLBACK_INTERVAL_SECS=10

# Object storage
OBJECT_STORAGE_BACKEND=minio
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=ielts-media
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_LOCAL_ROOT=./.data/object-store
MEDIA_BASE_URL=https://media.local.invalid

# Live mode and observability
LIVE_MODE_ENABLED=true
WORKER_OUTBOX_NOTIFY_CHANNEL=backend_outbox_wakeup
LIVE_MODE_NOTIFY_CHANNEL=backend_live_wakeup
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true
STORAGE_WARNING_BYTES=786432000
STORAGE_HIGH_WATER_BYTES=891289600
STORAGE_CRITICAL_BYTES=996147200

# Auth session lifetime
# - Absolute lifetime: hard cap (hours) from issuance
# - Idle timeouts: sliding window (minutes) from last activity
SESSION_ABSOLUTE_LIFETIME_HOURS=168
SESSION_IDLE_TIMEOUT_STAFF_MINUTES=480
SESSION_IDLE_TIMEOUT_STUDENT_MINUTES=60

# Rate limiting
# Set this to raise the default count-based limit across routes.
# Route-specific env vars still win when they are set.
RATE_LIMIT_GLOBAL=500
RATE_LIMIT_STUDENT_ENTRY_PER_IP_WINDOW_SECS=60
RATE_LIMIT_STUDENT_ENTRY_PER_SCHEDULE_WINDOW_SECS=600
RATE_LIMIT_STUDENT_BOOTSTRAP_PER_USER_WINDOW_SECS=60

# Frontend migration toggles
FEATURE_USE_BACKEND_BUILDER=false
FEATURE_USE_BACKEND_SCHEDULING=false
FEATURE_USE_BACKEND_DELIVERY=false
FEATURE_USE_BACKEND_PROCTORING=false
FEATURE_USE_BACKEND_GRADING=false

# Load testing
BACKEND_BASE_URL=http://127.0.0.1:4000
LOAD_TEST_SCENARIO=schedule-start-surge
LOAD_TEST_CONCURRENCY=25
LOAD_TEST_REQUESTS=100
LOAD_TEST_REQUEST_DELAY_MS=0
LOAD_TEST_BOOTSTRAP_PATH=/api/v1/student/sessions/00000000-0000-0000-0000-000000000000/bootstrap
LOAD_TEST_BOOTSTRAP_BODY={"studentKey":"candidate-1","candidateId":"candidate-1","candidateName":"Candidate 1","candidateEmail":"candidate1@example.com"}
LOAD_TEST_MUTATION_PATH=/api/v1/student/sessions/00000000-0000-0000-0000-000000000000/mutations:batch
LOAD_TEST_MUTATION_BODY={"attemptId":"00000000-0000-0000-0000-000000000000","studentKey":"candidate-1","clientSessionId":"00000000-0000-0000-0000-000000000000","mutations":[{"id":"mutation-1","seq":1,"mutationType":"answer.set","payload":{"questionId":"q1","value":"A"},"timestamp":"2026-04-17T00:00:00Z"}]}
LOAD_TEST_HEARTBEAT_PATH=/api/v1/student/sessions/00000000-0000-0000-0000-000000000000/heartbeat
LOAD_TEST_HEARTBEAT_BODY={"attemptId":"00000000-0000-0000-0000-000000000000","studentKey":"candidate-1","clientSessionId":"00000000-0000-0000-0000-000000000000","eventType":"heartbeat","payload":{},"clientTimestamp":"2026-04-17T00:00:00Z"}
LOAD_TEST_RESTART_AFTER_MS=2000
LOAD_TEST_RESTART_CMD_TIMEOUT_MS=60000
LOAD_TEST_RESTART_TRAFFIC_SCENARIO=heartbeat-sustained
LOAD_TEST_API_RESTART_CMD=
LOAD_TEST_WORKER_RESTART_CMD=

# Backup rehearsal
BACKUP_REHEARSAL_DB=ielts_restore_rehearsal

# Master Key Login (for admin/emergency access)
MASTER_KEY_ENABLED=true
MASTER_KEY_USERNAME=
MASTER_KEY_PASSWORD=
